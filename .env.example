# Copy this file to .env (same folder as docker-compose.yml) and fill in real values.
# .env is read automatically by docker-compose. Never commit the real .env file.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-value
POSTGRES_DB=security_db

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-value

# Comma-separated list of origins allowed to call the API directly
# (browsers calling it through the nginx proxy don't need to be listed —
# that traffic is same-origin).
ALLOWED_ORIGINS=http://localhost
